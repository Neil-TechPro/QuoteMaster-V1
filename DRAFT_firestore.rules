rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Phase 0: Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Phase 3: Primitive Definitions ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function getProfile(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isSuperAdmin() {
      return isEmailVerified() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getProfile(request.auth.uid).role == 'super_admin';
    }

    function isClientAdmin(tenantId) {
      return isEmailVerified() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getProfile(request.auth.uid).tenant_id == tenantId && 
             getProfile(request.auth.uid).role == 'client_admin';
    }

    function belongsToTenant(tenantId) {
      return isEmailVerified() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getProfile(request.auth.uid).tenant_id == tenantId;
    }

    function isDocOwner(docData) {
      return isSignedIn() && docData.id == request.auth.uid;
    }

    // --- Collection: Tenants ---
    match /tenants/{tenantId} {
      allow get: if isEmailVerified() && (isSuperAdmin() || belongsToTenant(tenantId));
      allow list: if isSuperAdmin();
      
      // Only Super Admins can create tenants in production, 
      // but we allow initial creation for onboarding.
      // HARDENING: Check that no existing user is linked to this tenant if being created by an user.
      allow create: if isEmailVerified() && isValidTenant(incoming());
      
      allow update: if isEmailVerified() && (
        isSuperAdmin() || 
        (isClientAdmin(tenantId) && incoming().diff(existing()).affectedKeys().hasOnly(['company_name', 'address', 'phone', 'gstin', 'state', 'bank_details', 'terms_conditions', 'updated_at']))
      ) && isValidTenant(incoming());
    }

    function isValidTenant(data) {
      return data.keys().hasAll(['company_name', 'is_active', 'quotation_prefix', 'invoice_prefix', 'quotation_counter', 'invoice_counter']) &&
             data.company_name is string && data.company_name.size() > 0 && data.company_name.size() <= 200 &&
             data.is_active is bool &&
             data.quotation_prefix is string && data.quotation_prefix.size() <= 20 &&
             data.invoice_prefix is string && data.invoice_prefix.size() <= 20 &&
             data.quotation_counter is int && data.quotation_counter >= 0 &&
             data.invoice_counter is int && data.invoice_counter >= 0 &&
             (data.gstin == null || (data.gstin is string && data.gstin.size() <= 20));
    }

    // --- Collection: Users ---
    match /users/{userId} {
      allow get: if isEmailVerified() && (
        request.auth.uid == userId || 
        isSuperAdmin() || 
        (belongsToTenant(existing().tenant_id))
      );
      
      allow list: if isEmailVerified() && (
        isSuperAdmin() || 
        (belongsToTenant(resource.data.tenant_id))
      );

      allow create: if isEmailVerified() && (
        isSuperAdmin() || 
        (
          // Self-creation for onboarding or invitation acceptance
          request.auth.uid == userId && 
          incoming().id == request.auth.uid &&
          incoming().email == request.auth.token.email &&
          // PRIVILEGE ESCALATION GUARD: Role must be correct
          (
            // If first user for tenant, can be admin
            (incoming().role == 'client_admin' && !exists(/databases/$(database)/documents/users/$(request.auth.uid))) ||
            // If joining via invitation, role is checked there (but here we just limit to non-superadmin)
            (incoming().role in ['client_admin', 'sales_rep'])
          ) &&
          isValidUser(incoming())
        )
      );

      allow update: if isEmailVerified() && (
        isSuperAdmin() || 
        (isClientAdmin(existing().tenant_id) && incoming().role in ['client_admin', 'sales_rep']) ||
        (request.auth.uid == userId && incoming().role == existing().role && incoming().tenant_id == existing().tenant_id)
      ) && isValidUser(incoming());
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'tenant_id', 'name', 'email', 'role', 'is_active']) &&
             data.id is string && data.id == request.auth.uid &&
             data.tenant_id is string && isValidId(data.tenant_id) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['super_admin', 'client_admin', 'sales_rep'] &&
             data.is_active is bool;
    }

    // --- Collection: Invitations ---
    match /invitations/{invId} {
      allow get, list: if isEmailVerified() && (
        isSuperAdmin() || 
        (resource.data.email == request.auth.token.email) ||
        (belongsToTenant(resource.data.tenant_id))
      );
      
      allow create: if isEmailVerified() && (
        isSuperAdmin() || 
        (isClientAdmin(incoming().tenant_id) && isValidInvitation(incoming()))
      );

      allow update: if isEmailVerified() && (
        isSuperAdmin() || 
        (isClientAdmin(existing().tenant_id) && isValidInvitation(incoming()))
      );
      
      allow delete: if isEmailVerified() && (
        isSuperAdmin() || 
        (isClientAdmin(existing().tenant_id)) || 
        (existing().email == request.auth.token.email)
      );
    }

    function isValidInvitation(data) {
      return data.keys().hasAll(['email', 'name', 'role', 'tenant_id', 'invited_by']) &&
             data.email is string && data.email.size() > 0 &&
             data.name is string && data.name.size() > 0 &&
             data.role in ['sales_rep', 'client_admin'] &&
             data.tenant_id is string && isValidId(data.tenant_id) &&
             data.invited_by == request.auth.uid;
    }

    // --- Collection: Products ---
    match /products/{productId} {
      allow read: if isEmailVerified() && belongsToTenant(resource.data.tenant_id);
      allow create: if isEmailVerified() && (isSuperAdmin() || isClientAdmin(incoming().tenant_id)) && isValidProduct(incoming());
      allow update: if isEmailVerified() && (isSuperAdmin() || isClientAdmin(existing().tenant_id)) && isValidProduct(incoming());
      allow delete: if isEmailVerified() && (isSuperAdmin() || isClientAdmin(existing().tenant_id));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['tenant_id', 'name', 'is_active']) &&
             data.tenant_id is string && isValidId(data.tenant_id) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.is_active is bool &&
             (data.default_price == null || data.default_price is number) &&
             (data.default_gst_rate == null || data.default_gst_rate is number);
    }

    // --- Collection: Clients ---
    match /clients/{clientId} {
      allow read: if isEmailVerified() && belongsToTenant(resource.data.tenant_id);
      allow create: if isEmailVerified() && (isSuperAdmin() || belongsToTenant(incoming().tenant_id)) && isValidClient(incoming());
      allow update: if isEmailVerified() && (isSuperAdmin() || belongsToTenant(existing().tenant_id)) && isValidClient(incoming());
      allow delete: if isEmailVerified() && (isSuperAdmin() || isClientAdmin(existing().tenant_id));
    }

    function isValidClient(data) {
      return data.keys().hasAll(['tenant_id', 'name']) &&
             data.tenant_id is string && isValidId(data.tenant_id) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200;
    }

    // --- Collection: Quotations ---
    match /quotations/{quotationId} {
      allow get: if isEmailVerified() && belongsToTenant(resource.data.tenant_id);
      allow list: if isEmailVerified() && belongsToTenant(resource.data.tenant_id);
      
      allow create: if isEmailVerified() && 
                    belongsToTenant(incoming().tenant_id) && 
                    incoming().sales_rep_id == request.auth.uid &&
                    existsAfter(/databases/$(database)/documents/tenants/$(incoming().tenant_id)) &&
                    isValidQuotation(incoming());

      allow update: if isEmailVerified() && (
        isSuperAdmin() || 
        isClientAdmin(existing().tenant_id) || 
        (existing().sales_rep_id == request.auth.uid && existing().status == 'draft')
      ) && isValidQuotation(incoming()) && (
        // Action: Change Status
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updated_at', 'notes']) ||
        // Action: Full Edit (only if not converted)
        (existing().status != 'converted' && incoming().diff(existing()).affectedKeys().hasAll(['status', 'items']))
      );

      allow delete: if isEmailVerified() && (isSuperAdmin() || isClientAdmin(existing().tenant_id));
    }

    function isValidQuotation(data) {
      return data.keys().hasAll(['tenant_id', 'quotation_number', 'client', 'sales_rep_id', 'status', 'items']) &&
             data.tenant_id is string && isValidId(data.tenant_id) &&
             data.quotation_number is string && data.quotation_number.size() > 0 &&
             data.sales_rep_id is string && isValidId(data.sales_rep_id) &&
             data.status in ['draft', 'sent', 'accepted', 'converted', 'expired'] &&
             data.items is list && data.items.size() <= 50 &&
             (data.items.size() == 0 || data.items[0].productName is string);
    }
  }
}
