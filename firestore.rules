rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getProfile(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getProfile(request.auth.uid).role == 'super_admin';
    }

    function isClientAdmin(tenantId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getProfile(request.auth.uid).tenant_id == tenantId && 
             getProfile(request.auth.uid).role == 'client_admin';
    }

    function belongsToTenant(tenantId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getProfile(request.auth.uid).tenant_id == tenantId;
    }

    // --- Collection: Tenants ---
    match /tenants/{tenantId} {
      allow get: if isSignedIn() && (isSuperAdmin() || exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getProfile(request.auth.uid).tenant_id == tenantId);
      allow list: if isSuperAdmin();
      allow create: if isSignedIn() && isValidTenant(incoming());
      allow update: if (isSuperAdmin() || isClientAdmin(tenantId)) && isValidTenant(incoming());
    }

    function isValidTenant(data) {
      return data.company_name is string && data.company_name.size() > 0 && data.company_name.size() <= 200 &&
             data.is_active is bool &&
             data.quotation_prefix is string && data.quotation_prefix.size() <= 20 &&
             data.invoice_prefix is string && data.invoice_prefix.size() <= 20 &&
             data.quotation_counter is int && data.invoice_counter is int;
    }

    // --- Collection: Users ---
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getProfile(request.auth.uid).tenant_id == resource.data.tenant_id));
      allow list: if isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getProfile(request.auth.uid).tenant_id == resource.data.tenant_id);
      allow create: if isSuperAdmin() || (isSignedIn() && incoming().id == request.auth.uid && isValidUser(incoming()));
      allow update: if (isSuperAdmin() || isClientAdmin(existing().tenant_id) || request.auth.uid == userId) && isValidUser(incoming());
    }

    // --- Collection: Invitations ---
    match /invitations/{invId} {
      allow get, list: if isSignedIn() && (
        isSuperAdmin() || 
        (resource.data.email != null && resource.data.email == request.auth.token.email) ||
        (resource.data.tenant_id != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getProfile(request.auth.uid).tenant_id == resource.data.tenant_id)
      );
      
      allow create: if isSuperAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getProfile(request.auth.uid).role == 'client_admin' && 
        getProfile(request.auth.uid).tenant_id == incoming().tenant_id &&
        isValidInvitation(incoming())
      );

      allow update: if isSuperAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getProfile(request.auth.uid).role == 'client_admin' && 
        getProfile(request.auth.uid).tenant_id == existing().tenant_id &&
        isValidInvitation(incoming())
      );
      
      allow delete: if isSuperAdmin() || (
        isSignedIn() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getProfile(request.auth.uid).tenant_id == existing().tenant_id && getProfile(request.auth.uid).role == 'client_admin') || 
          existing().email == request.auth.token.email
        )
      );
    }

    function isValidInvitation(data) {
      return data.email is string && data.email.size() > 0 &&
             data.role in ['sales_rep', 'client_admin'] &&
             data.tenant_id is string && isValidId(data.tenant_id);
    }

    function isValidUser(data) {
      return data.tenant_id is string && isValidId(data.tenant_id) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['super_admin', 'client_admin', 'sales_rep'] &&
             data.is_active is bool;
    }

    // --- Collection: Products ---
    match /products/{productId} {
      allow read: if isSignedIn() && belongsToTenant(resource.data.tenant_id);
      allow write: if (isSuperAdmin() || isClientAdmin(incoming().tenant_id)) && isValidProduct(incoming());
    }

    function isValidProduct(data) {
      return data.tenant_id is string && isValidId(data.tenant_id) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.is_active is bool &&
             (data.default_price == null || data.default_price is number) &&
             (data.default_gst_rate == null || data.default_gst_rate is number);
    }

    // --- Collection: Clients ---
    match /clients/{clientId} {
      allow read: if isSignedIn() && belongsToTenant(resource.data.tenant_id);
      allow write: if (isSuperAdmin() || belongsToTenant(incoming().tenant_id)) && isValidClient(incoming());
    }

    function isValidClient(data) {
      return data.tenant_id is string && isValidId(data.tenant_id) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200;
    }

    // --- Collection: Quotations ---
    match /quotations/{quotationId} {
      allow get: if isSignedIn() && belongsToTenant(resource.data.tenant_id);
      allow list: if isSignedIn() && belongsToTenant(resource.data.tenant_id);
      allow create: if belongsToTenant(incoming().tenant_id) && isValidQuotation(incoming());
      allow update: if belongsToTenant(existing().tenant_id) && isValidQuotation(incoming()) && (
        // Allow status updates by representative or admins
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updated_at', 'notes']) ||
        // Allow full updates only if not converted
        (existing().status != 'converted' && incoming().diff(existing()).affectedKeys().hasAll(['status', 'items']))
      );

      match /items/{itemId} {
        allow read: if isSignedIn() && belongsToTenant(get(/databases/$(database)/documents/quotations/$(quotationId)).data.tenant_id);
        allow write: if belongsToTenant(get(/databases/$(database)/documents/quotations/$(quotationId)).data.tenant_id) && isValidQuotationItem(incoming());
      }
    }

    function isValidQuotation(data) {
      return data.tenant_id is string && isValidId(data.tenant_id) &&
             data.quotation_number is string && data.quotation_number.size() > 0 &&
             data.client_id is string && isValidId(data.client_id) &&
             data.sales_rep_id == request.auth.uid &&
             data.status in ['draft', 'sent', 'accepted', 'converted', 'expired'];
    }

    function isValidQuotationItem(data) {
      return data.quotation_id is string && isValidId(data.quotation_id) &&
             data.product_name is string && data.product_name.size() > 0 &&
             data.quantity is number && data.quantity > 0 &&
             data.unit_price is number && data.unit_price >= 0;
    }
  }
}
